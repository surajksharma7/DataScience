val = int(input( """
    1--> cm to feet
    2--> km to miles 
    3 --> usd to inr 
    4 --> exit
    """))
if val == 1:
    cm = int(input("Enter value in centimeter "))
    foot = cm * 0.0328084
    print("The value in foot is {}".format(foot))
    
elif val ==2:
    km = int(input("Enter value in kilometer "))
    miles = km * 0.621371
    print("The distance in miles {}".format(miles))
    
elif val == 3:
    usd = int(input("enter value in usd "))
    inr = usd * 80 
    print("The price in inr  is {}".format(inr))
    
else:
    print("out of condition ")





